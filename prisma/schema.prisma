// Tiger Bot Scout v3.2.0 - Prisma Schema
// Updated with Gemini Red Team recommendations

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model Tenant {
  id              String   @id @default(uuid())
  stripeId        String?  @unique
  email           String   @unique
  name            String?

  // Bot Identity (Per-Customer Bot Architecture)
  botToken        String   @unique // AES-256 Encrypted
  botTokenHash    String   @unique // Public SHA-256 hash for Webhook Routing
  botUsername     String

  // NEW: Track which Admin Account created this bot (Gemini Red Team - 20 bot limit)
  createdByAdminSession  String?

  // Conversation State (for onboarding interview flow)
  state           String   @default("IDLE") // IDLE, WELCOME, INTERVIEW_1, INTERVIEW_2, KEY_PROMPT, ACTIVE, ERROR_RECOVERY
  chat_id         String?  // Telegram chat ID for this tenant
  interview_data  Json?    // Stores interview responses as JSON

  // Invite / Trial Tracking
  inviteTokenId   String?                            // Which invite was used to create this tenant
  trialEndsAt     DateTime?                          // null = permanent; set for trial tenants
  tier            String   @default("scout")         // scout, pro, enterprise

  status          String   @default("provisioning") // provisioning, active, suspended
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  prospects       Prospect[]
  reports         DailyReport[]
  supportTickets  SupportTicket[]
}

model Prospect {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Basic Info
  name            String
  email           String?
  phone           String?
  source          String?  // facebook, linkedin, instagram, referral
  sourceUrl       String?  // Profile URL
  
  // Enrichment Data (from Mini-RAG scraping)
  summary         String?  // AI-generated summary
  interests       String[] // Array of detected interests
  painPoints      String[] // Potential pain points
  
  // Scoring & Status
  score           Int      @default(0) // 0-100 AI-generated score
  status          String   @default("new") // new, contacted, interested, converted, rejected
  
  // Timestamps
  createdAt       DateTime @default(now())
  contactedAt     DateTime?
  convertedAt     DateTime?
  
  @@index([tenantId])
  @@index([status])
  @@index([score])
}

model DailyReport {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  date            DateTime @default(now())
  status          String   @default("pending") // pending, sent, failed
  prospectCount   Int      @default(0)
  
  // Report Content
  messageId       String?  // Telegram message ID if sent
  content         String?  // The actual report text
  
  createdAt       DateTime @default(now())
  sentAt          DateTime?
  
  @@index([tenantId])
  @@index([date])
}

model HivePattern {
  id              String   @id @default(uuid())
  
  // Pattern Content
  content         String   // The script template or objection handler
  category        String?  // approach_script, objection_handler, follow_up
  
  // Vector Embedding for Semantic Search (OpenAI text-embedding-3-small)
  embedding       Unsupported("vector(1536)")?
  
  // Success Tracking
  successCount    Int      @default(0)
  uses            Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([category])
}

// Credential Vault for secure secret storage
model CredentialVault {
  id              String   @id @default(uuid())
  tenantId        String
  
  credentialType  String   // telegram_session, facebook_cookie, linkedin_cookie, etc.
  encryptedValue  Bytes    // AES-256-GCM encrypted
  iv              Bytes    // Initialization vector
  
  createdAt       DateTime @default(now())
  lastAccessed    DateTime?
  expiresAt       DateTime?
  
  @@unique([tenantId, credentialType])
  @@index([tenantId])
}

// ==========================================
// F-05: FAILSAFE FEEDBACK LOOP
// Added: 2026-02-11
// ==========================================

model SupportTicket {
  id              String    @id @default(uuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  issue           String    // User's stated problem
  conversationLog String    // JSON array of last 10 messages
  status          String    @default("open") // 'open', 'in_progress', 'resolved'
  priority        String    @default("normal") // 'low', 'normal', 'high', 'urgent'
  createdAt       DateTime  @default(now())
  resolvedAt      DateTime?
  resolvedBy      String?   // Admin who resolved
}

// ==========================================
// F-06: OPENCLAW UPDATE TRACKING
// Added: 2026-02-11
// ==========================================

model SystemUpdate {
  id              String    @id @default(uuid())
  component       String    // 'openclaw', 'gateway', 'worker'
  fromVersion     String
  toVersion       String
  status          String    @default("available") // 'available', 'installing', 'completed', 'failed'
  triggeredBy     String?   // Admin who triggered update
  createdAt       DateTime  @default(now())
  completedAt     DateTime?
  errorLog        String?   // If failed, capture error
}

// ==========================================
// INVITE / GIFTING SYSTEM
// Added: 2026-02-18
// ==========================================

model InviteToken {
  id              String    @id @default(uuid())
  token           String    @unique               // URL-safe random hex (32 chars) - the claim URL key
  label           String?                         // Human label: "For Phil Hillibrand"
  fromName        String    @default("Brent Bryson") // Shown on claim page: "X has set you up with Tiger Bot Scout"
  createdBy       String    @default("admin")     // Admin who generated this invite

  // Pre-fill recipient info (optional)
  recipientEmail  String?                         // Pre-fills the claim form
  recipientName   String?                         // Pre-fills the claim form

  // Claim tracking
  claimedBy       String?                         // Email used to claim
  claimedAt       DateTime?
  tenantId        String?                         // Tenant created by this invite

  // Expiry & trial
  expiresAt       DateTime?                       // null = never expires
  trialDays       Int       @default(0)           // 0 = permanent gift; N = trial period

  // Soft revocation
  revokedAt       DateTime?

  createdAt       DateTime  @default(now())

  @@index([token])
  @@index([claimedBy])
}

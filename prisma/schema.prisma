// Tiger Claw Scout v4.0.0 - Prisma Schema
// Ambitious rebuild: Script Engine + Full Language Support
// Languages: th (Thai), vi (Vietnamese), id (Bahasa Indonesia), ms (Bahasa Melayu), es (Spanish), en (English)

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ==========================================
// TENANT
// One record per paying customer
// ==========================================

model Tenant {
  id              String   @id @default(uuid())
  stripeId        String?  @unique
  email           String   @unique
  name            String?

  // Bot Identity (Per-Customer Bot Architecture)
  botToken        String   @unique // AES-256 Encrypted
  botTokenHash    String   @unique // SHA-256 hash for webhook routing
  botUsername     String

  // Which admin BotFather account created this bot (20-bot limit tracking)
  createdByAdminSession  String?

  // Language & Locale
  // The language the customer wants their bot to speak and reports delivered in
  preferredLanguage  String  @default("th") // th, vi, id, ms, es, en

  // Conversation State (onboarding interview flow)
  state           String   @default("IDLE") // IDLE, WELCOME, INTERVIEW_1, INTERVIEW_2, ACTIVE, ERROR_RECOVERY
  chat_id         String?  // Telegram chat ID (set after customer sends /start)
  interview_data  Json?    // Structured ICP data from onboarding

  // Flavor — controls system prompt, tools, and prospect sources
  flavorSlug      String   @default("network-marketer") // "network-marketer", "airbnb-host", "lawyer", etc.

  // Invite / Trial Tracking
  inviteTokenId   String?
  trialEndsAt     DateTime?
  tier            String   @default("scout") // scout, pro, enterprise

  status          String   @default("provisioning") // provisioning, active, suspended
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  prospects       Prospect[]
  scripts         Script[]
  reports         DailyReport[]
  supportTickets  SupportTicket[]
}

// ==========================================
// PROSPECT
// One record per identified prospect
// ==========================================

model Prospect {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Identity
  name            String
  email           String?
  phone           String?

  // Source
  source          String?  // reddit, linkedin, facebook, instagram, line, whatsapp, tiktok
  sourceUrl       String?  // Direct link to the post or profile
  signals         String[] // Raw signals detected: posts, comments, keywords that triggered the find

  // Language to use for outreach to this prospect
  // Detected from source platform and content
  language        String   @default("th") // th, vi, id, ms, es, en

  // AI Enrichment
  summary         String?  // AI-generated summary of who this person is and why they're a fit
  interests       String[] // Detected interests
  painPoints      String[] // Detected pain points

  // Scoring
  score           Int      @default(0) // 0-100. Only 70+ delivered in daily reports.

  // Pipeline Status
  status          String   @default("new")
  // new        → found, not yet delivered
  // delivered  → appeared in a daily report
  // scripted   → script generated
  // contacted  → customer sent the script
  // replied    → prospect responded
  // converted  → prospect joined / purchased
  // archived   → not a fit, removed from pipeline

  // Timestamps
  createdAt       DateTime @default(now())
  deliveredAt     DateTime? // When included in a daily report
  scriptedAt      DateTime? // When script was generated
  contactedAt     DateTime? // When customer reached out
  repliedAt       DateTime? // When prospect replied
  convertedAt     DateTime? // When prospect converted

  scripts         Script[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, score(sort: Desc)])
  @@index([status])
}

// ==========================================
// SCRIPT
// The core product: personalized outreach scripts
// Generated by AI, tracked through outcome, fed into Hive
// ==========================================

model Script {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prospectId      String
  prospect        Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  // Language this script is written in
  language        String   // th, vi, id, ms, es, en

  // Script Components
  opening         String   // The opening message — what the customer actually sends first
  valueProp       String?  // Value proposition paragraph
  cta             String?  // Call to action
  objections      Json?    // Array of {objection: string, response: string}
  fullScript      String   // Complete formatted script ready to copy/send

  // AI Metadata
  aiModel         String?  // e.g. claude-opus-4-5-20251101
  promptVersion   String   @default("v1") // for A/B testing prompt iterations
  tokensUsed      Int?

  // Which Hive pattern seeded this script (if any)
  hivePatternId   String?
  hivePattern     HivePattern? @relation(fields: [hivePatternId], references: [id])

  // Outcome Tracking (set via feedback buttons 👎 / 👍 / 🎯)
  outcome         String?  // no_response, replied, converted
  feedbackAt      DateTime?
  rating          Int?     // 1-5 stars

  createdAt       DateTime @default(now())

  @@index([tenantId])
  @@index([prospectId])
  @@index([outcome])
  @@index([language])
}

// ==========================================
// HIVE PATTERN
// Shared learning across all tenants
// Successful scripts feed patterns in here
// Future scripts are seeded from here
// ==========================================

model HivePattern {
  id              String   @id @default(uuid())

  // Pattern Content
  content         String   // The script template or objection handler
  category        String?  // approach_script, objection_handler, follow_up, cta

  // Language this pattern works in
  language        String   @default("th") // th, vi, id, ms, es, en

  // Context tags for matching (market, product type, prospect signal type)
  tags            String[]

  // Vector Embedding for Semantic Search
  embedding       Unsupported("vector(1536)")?

  // Success Tracking
  uses            Int      @default(0)
  successCount    Int      @default(0)
  successRate     Float    @default(0) // recomputed on each feedback

  // Scripts that used this pattern and their outcomes feed back here
  scripts         Script[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
  @@index([language])
  @@index([language, category])
}

// ==========================================
// DAILY REPORT
// Log of every morning report sent
// ==========================================

model DailyReport {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  date            DateTime @default(now())
  status          String   @default("pending") // pending, sent, failed

  // What was in the report
  prospectCount   Int      @default(0)
  prospectIds     String[] // IDs of prospects included

  // Delivery
  messageId       String?  // Telegram message ID after send
  content         String?  // Full report text (for logging/debug)

  createdAt       DateTime @default(now())
  sentAt          DateTime?
  errorLog        String?

  @@index([tenantId])
  @@index([tenantId, date(sort: Desc)])
}

// ==========================================
// CREDENTIAL VAULT
// Encrypted storage for social media session cookies
// Used for authenticated prospect sourcing
// ==========================================

model CredentialVault {
  id              String   @id @default(uuid())
  tenantId        String

  credentialType  String   // facebook_cookie, line_session, instagram_cookie, linkedin_cookie
  encryptedValue  Bytes    // AES-256-GCM encrypted
  iv              Bytes    // Initialization vector

  createdAt       DateTime @default(now())
  lastAccessed    DateTime?
  expiresAt       DateTime?

  @@unique([tenantId, credentialType])
  @@index([tenantId])
}

// ==========================================
// SUPPORT TICKET
// Customer-reported issues via bot
// ==========================================

model SupportTicket {
  id              String    @id @default(uuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id])

  issue           String
  conversationLog String    // JSON: last 10 messages for context
  status          String    @default("open") // open, in_progress, resolved
  priority        String    @default("normal") // low, normal, high, urgent

  createdAt       DateTime  @default(now())
  resolvedAt      DateTime?
  resolvedBy      String?
}

// ==========================================
// FLAVOR
// Profession-specific tool + prompt configuration
// One record per supported profession/use-case
// ==========================================

model Flavor {
  id               String   @id @default(uuid())
  slug             String   @unique  // "network-marketer", "airbnb-host", "realtor", etc.
  name             String
  systemPrompt     String   // Full system prompt for this profession
  enabledTools     String[] // Tool names from src/fleet/tools/ that are active
  prospectSources  Json     @default("{}") // { subreddits, keywords, platforms }
  signalVocabulary Json     @default("{}") // { painPoints, triggers, exclusions }
  scriptTemplates  Json     @default("[]") // Opening message templates
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ==========================================
// INVITE TOKEN
// For gifted / comped / trial customers
// ==========================================

model InviteToken {
  id              String    @id @default(uuid())
  token           String    @unique
  label           String?
  fromName        String    @default("Brent Bryson")
  createdBy       String    @default("admin")

  recipientEmail  String?
  recipientName   String?

  claimedBy       String?
  claimedAt       DateTime?
  tenantId        String?

  expiresAt       DateTime?
  trialDays       Int       @default(0)
  revokedAt       DateTime?

  createdAt       DateTime  @default(now())

  @@index([token])
  @@index([claimedBy])
}

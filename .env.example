# Tiger Bot Scout v3.1.0 Environment Variables
# Copy this to .env and fill in your values

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/tiger_bot

# ============================================
# SERVER
# ============================================
PORT=4001
NODE_ENV=production

# ============================================
# REDIS (for BullMQ job queues)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# TELEGRAM API (for gramjs bot creation)
# Get these from https://my.telegram.org
# ============================================
TG_APP_ID=
TG_APP_HASH=
TG_PHONE=+1XXXXXXXXXX

# ============================================
# TELEGRAM BOT (legacy - per-bot tokens)
# ============================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_REPORT_CHAT_ID=
TELEGRAM_ALLOWED_USERS=

# ============================================
# AI SERVICES
# ============================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ============================================
# FLEET WORKER
# ============================================
CONCURRENCY=10

# ============================================
# INTEGRATIONS (optional)
# ============================================
APOLLO_API_KEY=
BREVO_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
CALENDLY_API_KEY=
CALENDLY_LINK=

# ============================================
# LINE (optional)
# ============================================
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ============================================
# STRIPE (for provisioning)
# ============================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

{
  "name": "tiger-bot-scout",
  "version": "3.1.0",
  "description": "Tiger Bot Scout - AI Recruiting Partner for Network Marketing (Virtual Fleet Architecture)",
  "type": "module",
  "main": "dist/gateway/index.js",
  "scripts": {
    "dev:gateway": "tsx watch src/gateway/index.ts",
    "dev:worker": "tsx watch src/fleet/worker.ts",
    "build": "tsc",
    "start:gateway": "node dist/src/gateway/index.js",
    "start:worker": "node dist/src/fleet/worker.js",
    "start:cluster": "pm2 start ecosystem.config.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "generate-session": "tsx src/provisioner/session-generator.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "final-login": "npx tsx final_login.ts",
    "provision-all": "npx tsx provision-all-bots.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@jest/globals": "^30.2.0",
    "@prisma/client": "^5.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "axios": "^1.13.5",
    "bullmq": "^5.4.0",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "input": "^1.0.1",
    "ioredis": "^5.3.2",
    "node-cron": "^4.2.1",
    "node-telegram-bot-api": "^0.66.0",
    "openai": "^4.28.0",
    "pg": "^8.18.0",
    "puppeteer": "^22.0.0",
    "supertest": "^7.2.2",
    "telegram": "^2.22.2",
    "twilio": "^5.12.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.5",
    "@types/node-telegram-bot-api": "^0.64.7",
    "prisma": "^5.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^1.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "BotCraftWrks.ai",
  "license": "UNLICENSED",
  "private": true
}

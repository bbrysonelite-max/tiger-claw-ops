{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "resolveJsonModule": true,
    "downlevelIteration": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "api/**/*.ts", "tests/**/*.ts", "types/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
